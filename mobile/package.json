{
  "name": "@salon/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:prod": "EXPO_PUBLIC_USE_FIREBASE_EMULATOR=false expo start",
    "start:emulator": "EXPO_PUBLIC_USE_FIREBASE_EMULATOR=true expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eas-build-post-install": "npm run build --workspace @salon/shared",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@salon/shared": "*",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.13",
    "expo-auth-session": "~7.0.11",
    "expo-crypto": "~15.0.9",
    "expo-notifications": "~0.32.17",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "firebase": "^11.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.0",
    "typescript": "^5.6.0"
  }
}
